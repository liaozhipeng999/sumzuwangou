# LLM Configuration - 使用 Ollama
LLM_API_BASE=http://localhost:11434/api
LLM_API_KEY=ollama
LLM_MODEL_NAME=qwen2.5:7b

# Chroma Database
CHROMA_PERSIST_DIR=./data/chroma_db

# Redis (Optional)
REDIS_URL=redis://localhost:6379/0

# Context Settings
