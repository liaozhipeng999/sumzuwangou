ALLOWED_FILE_TYPES=.txt,.md,.pdf,.doc,.docx

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
